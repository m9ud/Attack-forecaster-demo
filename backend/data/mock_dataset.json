  "scenarioPresets": {
    "A": {
      "label": "What if Arselan gets GenericAll on IT Admins?",
      "description": "Arselan (a lab student) finds a misconfigured ACL granting GenericAll on IT Admins — 2-hop path straight to cis-dc01.",
      "mutations": [
        { "type": "addEdge", "source": "Arselan", "relation": "GenericAll", "target": "IT Admins", "weight": 9 }
      ]
    },
    "B": {
      "label": "What if khalid.day gets AdminTo on cis-dc01?",
      "description": "khalid.day is granted local admin on the CIS Domain Controller — a one-hop compromise of the crown jewel.",
      "mutations": [
        { "type": "addEdge", "source": "khalid.day", "relation": "AdminTo", "target": "cis-dc01", "weight": 7 }
      ]
    },
    "C": {
      "label": "What if we revoke DCS IT Admins → GenericAll → cis-dc01?",
      "description": "Remove the cross-domain trust (E16). Eliminates all DCS-to-CIS domain compromise paths.",
      "mutations": [
        { "type": "removeEdge", "edgeId": "E16" }
      ]
    },
    "D": {
      "label": "What if we block mudrek → khalid.day ForceChangePassword?",
      "description": "Revoke mudrek's ForceChangePassword on khalid.day (E25) — cuts the escalation chain at its root.",
      "mutations": [
        { "type": "removeEdge", "edgeId": "E25" }
      ]
    },
    "E": {
      "label": "What if touzene loses GenericAll on cis-dc01?",
