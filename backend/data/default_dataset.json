  "scenarioPresets": {
    "A": {
      "label": "What if arya.stark gets GenericAll on Domain Admins?",
      "description": "arya.stark acquires GenericAll on Domain Admins, giving her a direct 2-hop path to kingslanding bypassing all intermediate nodes.",
      "mutations": [
        { "type": "addEdge", "source": "arya.stark", "relation": "GenericAll", "target": "Domain Admins", "weight": 9 }
      ]
    },
    "B": {
      "label": "What if hodor gets AdminTo on kingslanding?",
      "description": "Even the weakest user gains direct local admin access to the Domain Controller.",
      "mutations": [
        { "type": "addEdge", "source": "hodor", "relation": "AdminTo", "target": "kingslanding", "weight": 7 }
      ]
    },
    "C": {
      "label": "What if castelblack has a session of cersei.lannister?",
      "description": "Cross-domain credential exposure: cersei.lannister logs into castelblack, letting anyone with access to that server steal Domain Admin credentials.",
      "mutations": [
        { "type": "addEdge", "source": "castelblack", "relation": "HasSession", "target": "cersei.lannister", "weight": 6 }
      ]
    },
    "D": {
      "label": "What if we revoke lord.varys → GenericAll → Domain Admins?",
      "description": "Remove the most critical ACE — lord.varys' GenericAll on Domain Admins (E60). This is the single most dangerous shortcut to domain compromise.",
      "mutations": [
        { "type": "removeEdge", "edgeId": "E60" }
      ]
    },
    "E": {
      "label": "What if we revoke stannis → GenericAll → kingslanding?",
      "description": "Remove stannis.baratheon's GenericAll on the DC (E58). Blocks the culmination of the Lannister ACL chain that reaches the Domain Controller.",
      "mutations": [
        { "type": "removeEdge", "edgeId": "E58" }
      ]
    },
    "F": {
      "label": "What if we break the Lannister ACL chain?",
      "description": "Revoke tywin.lannister's ForceChangePassword on jaime.lannister (E51). Cuts the entry point of the elaborate 8-hop ACL escalation chain.",
      "mutations": [
        { "type": "removeEdge", "edgeId": "E51" }
      ]
    }
  }
